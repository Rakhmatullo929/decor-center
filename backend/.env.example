# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://localhost:5432/depo

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_HOURS=12

# Domain settings (SRS §15 open questions — agreed defaults)
DEPO_QUESTIONS_PER_TEST=10
DEPO_PASS_THRESHOLD=8
# Face match threshold. With the real InsightFace backend this is the MIN cosine similarity
# (higher = stricter; ~0.5 forgiving, ~0.6 strict). Unused by the mock backend.
DEPO_FACE_SIMILARITY_THRESHOLD=0.6
DEPO_TESTGEN_LANGUAGE=uz

# Integration backends (dotted paths; mocks by default).
# Enable real ArcFace recognition: DEPO_FACE_BACKEND=apps.integrations.insightface_adapter.InsightFaceAdapter
DEPO_FACE_BACKEND=apps.integrations.mocks.MockFaceRecognitionService
# InsightFace adapter tuning (only used when the InsightFace backend is active):
DEPO_FACE_INSIGHTFACE_MODEL=buffalo_sc   # model pack: buffalo_sc (default) / buffalo_l
DEPO_FACE_DET_SIZE=640                    # detector input size in px
DEPO_TESTGEN_BACKEND=apps.integrations.mocks.MockTestGeneratorService
# UzbekVoice TTS (SRS §12.2). Uzbek-only; Russian falls back to browser speech.
# Audio is generated by a post_save signal on Question when an approved specialty
# question is saved — set UZBEKVOICE_API_KEY to enable; leave it empty to disable.
# Set DEPO_TTS_ASYNC=false to synthesize inline (default true = background thread).
# Voices: lola (default), shoira. Get a key at https://uzbekvoice.ai
DEPO_TTS_VOICE_UZ=lola
UZBEKVOICE_API_KEY=

# Multi-photo face enrollment (all optional; sensible defaults in settings)
DEPO_FACE_MAX_PHOTOS=5
DEPO_FACE_MIN_FACE_PIXELS=80
DEPO_FACE_BLUR_MIN_VARIANCE=0          # 0 = blur check disabled
# (anti-duplicate uses the same threshold as live matching: DEPO_FACE_SIMILARITY_THRESHOLD)
DEPO_ANTI_SPOOFING_BACKEND=apps.integrations.mocks.MockAntiSpoofingService
DEPO_ANTI_SPOOFING_ENABLED=False
DEPO_ANTI_SPOOFING_THRESHOLD=0.5
DEPO_FACE_WARMUP_ON_STARTUP=False      # set True in production (gunicorn) to preload the model

# Submit-time face re-verification (exam integrity): off | log | block.
# 'log' (default) captures a frame at submit and logs mismatches without blocking;
# switch to 'block' once the similarity threshold is tuned to reject impostor submits.
DEPO_REVERIFY_ON_SUBMIT=log

# Seed accounts (used by `manage.py seed_initial_data`)
DEPO_ADMIN_PASSWORD=admin12345!
DEPO_MEDIC_PASSWORD=medic12345!
DEPO_SPECIALIST_PASSWORD=specialist12345!
