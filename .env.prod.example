# Production env for depo. Copy to /home/rakhmonov/depo/.env on the server and fill in
# real secrets. NEVER commit the filled-in .env. Compose reads this file for both
# ${VAR} interpolation and the backend container env (env_file).

DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=__generate_50+_random_chars__
DJANGO_ALLOWED_HOSTS=api.lokomotiv-depo.uz,lokomotiv-depo.uz,www.lokomotiv-depo.uz,207.180.210.65,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://lokomotiv-depo.uz,https://www.lokomotiv-depo.uz
DJANGO_CSRF_TRUSTED_ORIGINS=https://lokomotiv-depo.uz,https://www.lokomotiv-depo.uz,https://api.lokomotiv-depo.uz
DJANGO_SECURE_SSL_REDIRECT=True

POSTGRES_DB=depo
POSTGRES_USER=depo
POSTGRES_PASSWORD=__generate_strong__

# Real face recognition (model is baked into the image; warms up per worker)
DEPO_FACE_BACKEND=apps.integrations.insightface_adapter.InsightFaceAdapter
DEPO_FACE_WARMUP_ON_STARTUP=true
DEPO_FACE_SIMILARITY_THRESHOLD=0.5

# Set to 1 on a DB that already holds imported/real data so the entrypoint does NOT
# re-assert the canonical specialty roster on each start. Leave unset on a fresh deploy.
DEPO_SKIP_SEED=0

# Strong passwords for the seeded system accounts (seed_initial_data reads these)
DEPO_ADMIN_PASSWORD=__generate_strong__
DEPO_MEDIC_PASSWORD=__generate_strong__
DEPO_SPECIALIST_PASSWORD=__generate_strong__

# TTS (reuse the key from the local backend/.env)
UZBEKVOICE_API_KEY=__from_local_backend_env__
DEPO_TTS_VOICE_UZ=lola
