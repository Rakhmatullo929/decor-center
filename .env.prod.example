# Production env for decor. Copy to /home/rakhmonov/decor/.env on the server and fill in
# real secrets. NEVER commit the filled-in .env. Compose reads this file for both
# ${VAR} interpolation and the backend container env (env_file).

DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=__generate_50+_random_chars__
DJANGO_ALLOWED_HOSTS=api.lokomotiv-decor.uz,lokomotiv-decor.uz,www.lokomotiv-decor.uz,207.180.210.65,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://lokomotiv-decor.uz,https://www.lokomotiv-decor.uz
DJANGO_CSRF_TRUSTED_ORIGINS=https://lokomotiv-decor.uz,https://www.lokomotiv-decor.uz,https://api.lokomotiv-decor.uz
DJANGO_SECURE_SSL_REDIRECT=True

POSTGRES_DB=decor
POSTGRES_USER=decor
POSTGRES_PASSWORD=__generate_strong__

# Real face recognition (model is baked into the image; warms up per worker)
DECOR_FACE_BACKEND=apps.integrations.insightface_adapter.InsightFaceAdapter
DECOR_FACE_WARMUP_ON_STARTUP=true
DECOR_FACE_SIMILARITY_THRESHOLD=0.5

# Set to 1 on a DB that already holds imported/real data so the entrypoint does NOT
# re-assert the canonical specialty roster on each start. Leave unset on a fresh deploy.
DECOR_SKIP_SEED=0

# Strong passwords for the seeded system accounts (seed_initial_data reads these)
DECOR_ADMIN_PASSWORD=__generate_strong__
DECOR_EMPLOYEE_PASSWORD=__generate_strong__

# TTS (reuse the key from the local backend/.env)
UZBEKVOICE_API_KEY=__from_local_backend_env__
DECOR_TTS_VOICE_UZ=lola
