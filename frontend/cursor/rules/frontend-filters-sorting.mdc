## Server-Side Sorting — TableHeadCustom

### Head cell definition

Each sortable column declares its Django ordering field via `sortKey`:

```ts
type HeadCell = {
  id: string;      // column identifier (camelCase)
  label: string;
  sortKey?: string; // Django ordering field (snake_case); omit for non-sortable columns
};

const tableHead: HeadCell[] = [
  { id: 'name', label: tx('common.table.name'), sortKey: 'name' },
  { id: 'category', label: tx('common.table.category'), sortKey: 'category__name' },
  { id: 'totalQuantity', label: tx('common.table.qty'), sortKey: 'total_quantity' },
  { id: '', label: '' }, // actions column — no sortKey → not sortable
];
```

### Parse ordering → (orderBy, order)

```ts
const { tableOrderBy, tableOrder } = useMemo(() => {
  const isDesc = ordering.startsWith('-');
  const field = isDesc ? ordering.slice(1) : ordering;
  const col = tableHead.find((h) => h.sortKey === field);
  return {
    tableOrderBy: col?.id ?? '',
    tableOrder: isDesc ? 'desc' as const : 'asc' as const,
  };
}, [ordering, tableHead]);
```

### Handle column click

```ts
const handleSort = useCallback(
  (columnId: string) => {
    const col = tableHead.find((h) => h.id === columnId);
    if (!col?.sortKey) return;
    const isCurrentAsc = tableOrderBy === columnId && tableOrder === 'asc';
    setOrdering(isCurrentAsc ? `-${col.sortKey}` : col.sortKey);
  },
  [tableHead, tableOrderBy, tableOrder, setOrdering]
);
```

### Wire into TableHeadCustom

```tsx
<TableHeadCustom
  order={tableOrder}
  orderBy={tableOrderBy}
  onSort={handleSort}
  headLabel={tableHead}
  ...
/>
```

